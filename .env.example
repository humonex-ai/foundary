# Foundry configuration. Copy to .env and fill in.

# Required: Anthropic API key for the LLM client.
ANTHROPIC_API_KEY=

# Optional: model id. Defaults to claude-sonnet-4-6.
# FOUNDRY_MODEL=claude-sonnet-4-6

# Optional: output root for generated artifacts. Defaults to projects.
# FOUNDRY_PROJECTS_DIR=projects

# Execution V1 (GitHub Issue sync). Optional — only the GitHub CLI commands use
# these. Token needs repo / issues:write scope.
# GITHUB_TOKEN=
# FOUNDRY_DEFAULT_REPO=owner/repo

# MCP server (foundry-mcp) reuses the variables above — no new env vars.
