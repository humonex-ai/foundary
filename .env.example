# Foundry configuration. Copy to .env and fill in. All variables are OPTIONAL.
#
# Primary path (system of record — submit_project): needs no Anthropic key.
# GITHUB_TOKEN: needed only for sync_github.
# ANTHROPIC_API_KEY: needed only for the legacy generator tools
#   (create_project / regenerate). The server starts and the primary path works
#   without it (06-decisions.md D-013).

# GitHub Issue sync (sync_github only). Token needs repo / issues:write scope.
# GITHUB_TOKEN=
# FOUNDRY_DEFAULT_REPO=owner/repo

# Legacy generator only: Anthropic API key (create_project / regenerate).
# ANTHROPIC_API_KEY=

# Legacy generator only: model id. Defaults to claude-sonnet-4-6.
# FOUNDRY_MODEL=claude-sonnet-4-6

# Optional: output root for artifacts. Defaults to projects.
# FOUNDRY_PROJECTS_DIR=projects
